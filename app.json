{
  "expo": {
    "name": "MedVault",
    "slug": "medvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medvault",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "MedVault needs camera access to scan medicine labels and identify medications."
        }
      ],
      [
        "expo-notifications",
        {
          "icons": [
            {
              "iconId": "ic_notification",
              "file": "./assets/images/icon.png"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
